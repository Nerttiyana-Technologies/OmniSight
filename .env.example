# --- Datastores ---
# Primary store. If unset, the API falls back to an in-memory store seeded from
# the CISA KEV fixture (great for a zero-dependency demo: just `pnpm dev`).
DATABASE_URL=postgres://omnisight:omnisight@localhost:5432/omnisight
# Queue + cache. Required by the worker; optional for the API.
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=4000
# Global per-IP rate limiting (protects every route). Tune for your traffic.
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

# --- Auth (opt-in) ---
# Leave AUTH_ENABLED=false to run open (default). Set true to require login.
AUTH_ENABLED=false
JWT_SECRET=
JWT_EXPIRY_HOURS=12
# Seeded on first boot when auth is on and there are no users yet.
ADMIN_USER=admin
ADMIN_PASS=

# --- SSO / OIDC (optional; requires AUTH_ENABLED=true) ---
# Generic authorization-code flow. Set all of these to show a "Sign in with SSO"
# button. New users are auto-provisioned as 'viewer' on first login.
# OIDC_LABEL=Okta
# OIDC_AUTH_URL=https://YOUR_IDP/authorize
# OIDC_TOKEN_URL=https://YOUR_IDP/token
# OIDC_USERINFO_URL=https://YOUR_IDP/userinfo
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:4000/api/auth/sso/callback
# OIDC_SCOPE=openid email profile
# Where the dashboard is served (the SSO callback redirects the browser here).
# APP_URL=http://localhost:5173

# --- AI layer (optional; local Ollama or any OpenAI-compatible endpoint) ---
# Powers CVE/advisory summaries and the natural-language "Ask AI" query box.
# For Ollama (running locally): LLM_BASE_URL=http://localhost:11434/v1 (no key).
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=llama3.1

# --- Optional connector credentials (keyless connectors work without these) ---
# NVD (free key: https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=
# abuse.ch (free key: https://auth.abuse.ch) — URLhaus / ThreatFox / MalwareBazaar
ABUSECH_AUTH_KEY=
# AlienVault OTX (free key: https://otx.alienvault.com)
OTX_API_KEY=
# Pulsedive (free key: https://pulsedive.com/register) — uses the free REST
# Explore API (50 results/request), NOT the paid TAXII server. Optional query
# override (Explore syntax) and result limit.
PULSEDIVE_API_KEY=
# PULSEDIVE_QUERY=risk=high or risk=critical
# PULSEDIVE_LIMIT=50
# Optional IOC-enrichment providers (Shodan InternetDB is keyless and always on)
GREYNOISE_API_KEY=
ABUSEIPDB_API_KEY=

# --- TAXII 2.1 polling (optional) ---
# Add TAXII feeds via the dashboard's "Add feed" panel (kind=taxii) or POST
# /api/sources. Per-feed auth lives in the source config; these are a global
# fallback for a single-server setup. Basic (user/pass) or Bearer (token).
TAXII_TOKEN=
TAXII_USER=
TAXII_PASS=

# --- Breach exposure (Have I Been Pwned) ---
# Comma-separated domains to monitor for known breaches. OmniSight pulls the FREE
# public breaches collection (no API key) and filters it to your domains locally,
# so no paid HIBP subscription is required. Leave HIBP_DOMAINS blank to disable.
# The worker checks daily at 05:00. HIBP_API_KEY is optional (raises rate limits).
HIBP_DOMAINS=
HIBP_API_KEY=

# --- Daily brief email (optional) ---
# If SMTP_HOST and DIGEST_TO are set, the worker emails the brief each morning.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=OmniSight <omnisight@localhost>
DIGEST_TO=
# Send one brief immediately on worker start (handy for testing the email setup).
DIGEST_ON_START=false

# --- My Stack alerts (optional) ---
# Webhook (Slack-compatible: posts {"text": ...}) and/or email recipient.
ALERT_WEBHOOK=
ALERT_TO=
# Alert when a stack-affecting vuln is exploited (KEV) or risk >= this score.
# NOTE: these defaults apply only when NO automation rules exist. Once you add
# rules (dashboard → Automation rules), the worker evaluates those instead.
ALERT_MIN_RISK=75

# --- SOAR-lite ticketing (optional): open a Jira issue per stack-affecting vuln ---
# Jira Cloud REST v2. Create an API token at id.atlassian.com.
# JIRA_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=SEC
# JIRA_ISSUE_TYPE=Task
# JIRA_MAX_TICKETS=10

# Delete indicators not seen in this many days (IOC decay). Set high to disable.
DECAY_PRUNE_DAYS=180

# --- Phase 2: defensive monitoring — environment events ---
# Opt-in syslog listener in the worker (UDP + TCP). Observables in incoming log
# lines are extracted and matched against tracked indicators. Off by default.
SYSLOG_ENABLED=false
SYSLOG_PORT=5514
# Delete environment events older than this many days (retention).
EVENTS_PRUNE_DAYS=30

# --- Phase 3: vulnerability scanning ---
# The built-in scanner (TCP port sweep + HTTP banner/header checks) is keyless
# and always available. To also use ProjectDiscovery nuclei, install the `nuclei`
# binary on PATH and set this to true; otherwise it is skipped automatically.
# Only scan systems you are authorized to test.
SCANNER_NUCLEI=false
# Defense-in-depth: cloud-metadata/link-local targets are always refused. Set
# true to also refuse all private/loopback ranges (e.g. on a hosted instance).
SCANNER_BLOCK_PRIVATE=false
